# Daily Horoscope Agent - Environment Variables
# This single .env file serves both frontend and backend

# ============================================
# BACKEND CONFIGURATION
# ============================================

# Server Configuration
PORT=8000
HOST=0.0.0.0

# CORS - Frontend URL (update for production)
FRONTEND_URL=https://daily-horoscope-agent-fronted.onrender.com

# Debug Mode (set to False in production)
DEBUG=True

# Cache TTL in seconds (default: 1 hour)
CACHE_TTL=3600

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Backend API URL (Vite requires VITE_ prefix for env vars exposed to browser)
VITE_API_URL=https://daily-horoscope-agent-backend.onrender.com
